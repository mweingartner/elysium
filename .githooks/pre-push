#!/bin/sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

stage() {
    printf '\n==> pre-push: %s\n' "$*"
}

fail() {
    printf 'pre-push failed: %s\n' "$*" >&2
    exit 1
}

stage "source security scan"
if [ -f scripts/security-scan.sh ]; then
    bash scripts/security-scan.sh
else
    fail "scripts/security-scan.sh not found"
fi

stage "release build without warnings"
BUILD_LOG="$(mktemp /tmp/pebble-pre-push-build.XXXXXX)"
if ! swift build -c release 2>&1 | tee "$BUILD_LOG"; then
    rm -f "$BUILD_LOG"
    fail "release build failed"
fi
if grep -q 'warning:' "$BUILD_LOG"; then
    rm -f "$BUILD_LOG"
    fail "release build emitted warnings"
fi
rm -f "$BUILD_LOG"

stage "xctest"
swift test

stage "golden suite"
swift run -c release pebsmoke

stage "pass"
